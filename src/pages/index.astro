---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cool Carts Rental | Golf Cart Rentals in Wildwood, FL">

  <!-- NAVBAR -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#000094] shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-white font-bold text-lg tracking-wide hover:opacity-80 transition-opacity" style="font-family: Montserrat, sans-serif;">
        <span class="text-[#ffca1c]">Cool</span> Carts Rental
      </a>
      <a
        href="tel:+17722628273"
        class="flex items-center gap-2 bg-[#ffca1c] text-[#000094] font-bold text-sm px-4 py-2 rounded-full hover:bg-yellow-300 transition-colors"
        style="font-family: Montserrat, sans-serif;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        (772) 262-8273
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <div class="absolute inset-0">
      <img
        src="/images/img-hero.webp"
        alt="Golf cart rental in Wildwood FL"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,148,0.85) 0%, rgba(0,0,148,0.6) 50%, rgba(0,0,0,0.3) 100%);"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-24 text-white">
      <div class="max-w-2xl">
        <p class="text-[#ffca1c] font-semibold text-sm tracking-[4px] uppercase mb-4" style="font-family: Montserrat, sans-serif;">
          Wildwood, FL
        </p>
        <h1 class="font-black text-5xl md:text-6xl leading-tight mb-6" style="font-family: Montserrat, sans-serif;">
          Rent a Golf Cart<br />in Wildwood, FL
        </h1>
        <p class="text-xl text-white/90 mb-8 leading-relaxed" style="font-family: Montserrat, sans-serif;">
          Premium AC-equipped golf carts with power windows and power steering. Daily, weekly &amp; monthly rentals starting at <strong class="text-[#ffca1c]">$70/day</strong>. <strong class="text-[#ffca1c]">We deliver!</strong>
        </p>
        <a
          href="#reserve"
          class="inline-block bg-[#ffca1c] text-[#000094] font-bold text-lg px-8 py-4 rounded-full hover:bg-yellow-300 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          style="font-family: Montserrat, sans-serif;"
        >
          Reserve Your Cart →
        </a>
      </div>
    </div>
  </section>

  <!-- FLEET -->
  <section id="fleet" class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-[#000094] font-semibold text-sm tracking-[4px] uppercase mb-2" style="font-family: Montserrat, sans-serif;">Available Now</p>
        <h2 class="text-4xl font-black text-gray-900" style="font-family: Montserrat, sans-serif;">Our Fleet</h2>
        <p class="text-gray-500 mt-3" style="font-family: Montserrat, sans-serif;">AC-equipped carts with power windows &amp; power steering — the only ones in the US</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        {[
          { src: '/images/kart-blue.webp', label: 'Blue' },
          { src: '/images/kart-red.webp', label: 'Red' },
          { src: '/images/kart-white.webp', label: 'White' },
          { src: '/images/kart-yellow.webp', label: 'Yellow' },
          { src: '/images/kart-pewter.webp', label: 'Pewter' },
        ].map(({ src, label }) => (
          <div class="group cursor-pointer" onclick="document.getElementById('reserve').scrollIntoView({behavior:'smooth'})">
            <div class="rounded-2xl overflow-hidden shadow-md group-hover:shadow-xl transition-all group-hover:-translate-y-1">
              <img src={src} alt={`${label} golf cart rental`} class="w-full aspect-square object-cover" />
            </div>
            <p class="text-center font-semibold text-gray-700 mt-2 text-sm" style="font-family: Montserrat, sans-serif;">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="bg-[#f5f7fa] py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-[#000094] font-semibold text-sm tracking-[4px] uppercase mb-2" style="font-family: Montserrat, sans-serif;">Simple &amp; Transparent</p>
        <h2 class="text-4xl font-black text-gray-900" style="font-family: Montserrat, sans-serif;">Rental Pricing</h2>
        <p class="text-gray-500 mt-3" style="font-family: Montserrat, sans-serif;">3-day minimum rental required</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <!-- Daily -->
        <div class="bg-white rounded-3xl p-8 shadow-md text-center border-2 border-[#000094] relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#000094] text-white text-xs font-bold px-4 py-1 rounded-full" style="font-family: Montserrat, sans-serif;">MOST POPULAR</div>
          <div class="text-[#000094] font-bold text-sm tracking-widest uppercase mb-3" style="font-family: Montserrat, sans-serif;">Daily</div>
          <div class="flex items-end justify-center gap-1 mb-4">
            <span class="text-5xl font-black text-gray-900" style="font-family: Montserrat, sans-serif;">$70</span>
            <span class="text-gray-500 mb-2" style="font-family: Montserrat, sans-serif;">/day</span>
          </div>
          <p class="text-gray-500 text-sm mb-6" style="font-family: Montserrat, sans-serif;">3-day minimum</p>
          <a href="#reserve" class="block w-full bg-[#000094] text-white font-bold py-3 rounded-full hover:bg-blue-900 transition-colors" style="font-family: Montserrat, sans-serif;">Reserve Now</a>
        </div>
        <!-- Weekly -->
        <div class="bg-white rounded-3xl p-8 shadow-md text-center">
          <div class="text-[#000094] font-bold text-sm tracking-widest uppercase mb-3" style="font-family: Montserrat, sans-serif;">Weekly</div>
          <div class="flex items-end justify-center gap-1 mb-4">
            <span class="text-5xl font-black text-gray-900" style="font-family: Montserrat, sans-serif;">$300</span>
            <span class="text-gray-500 mb-2" style="font-family: Montserrat, sans-serif;">/week</span>
          </div>
          <p class="text-gray-500 text-sm mb-6" style="font-family: Montserrat, sans-serif;">7 days</p>
          <a href="#reserve" class="block w-full bg-[#ffca1c] text-[#000094] font-bold py-3 rounded-full hover:bg-yellow-300 transition-colors" style="font-family: Montserrat, sans-serif;">Get a Quote</a>
        </div>
        <!-- Monthly -->
        <div class="bg-white rounded-3xl p-8 shadow-md text-center">
          <div class="text-[#000094] font-bold text-sm tracking-widets uppercase mb-3" style="font-family: Montserrat, sans-serif;">Monthly</div>
          <div class="flex items-end justify-center gap-1 mb-4">
            <span class="text-5xl font-black text-gray-900" style="font-family: Montserrat, sans-serif;">$1,050</span>
            <span class="text-gray-500 mb-2" style="font-family: Montserrat, sans-serif;">/mo</span>
          </div>
          <p class="text-gray-500 text-sm mb-6" style="font-family: Montserrat, sans-serif;">Best rate available</p>
          <a href="#reserve" class="block w-full bg-[#ffca1c] text-[#000094] font-bold py-3 rounded-full hover:bg-yellow-300 transition-colors" style="font-family: Montserrat, sans-serif;">Get a Quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-[#000094] py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-[#ffca1c] font-semibold text-sm tracking-[4px] uppercase mb-2" style="font-family: Montserrat, sans-serif;">Easy Process</p>
        <h2 class="text-4xl font-black text-white" style="font-family: Montserrat, sans-serif;">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {[
          { step: '01', title: 'Submit Your Request', desc: 'Fill out our simple form with your dates, cart preference, and contact info.' },
          { step: '02', title: 'We Confirm Availability', desc: "We'll reach out quickly to confirm your cart and go over any details." },
          { step: '03', title: 'We Deliver to You', desc: 'We deliver your cart directly to your location. No pickup needed — just tell us where and when.' },
        ].map(({ step, title, desc }) => (
          <div class="text-center">
            <div class="text-[#ffca1c] font-black text-6xl mb-4 opacity-40" style="font-family: Montserrat, sans-serif;">{step}</div>
            <h3 class="text-white font-bold text-xl mb-3" style="font-family: Montserrat, sans-serif;">{title}</h3>
            <p class="text-white/70 leading-relaxed" style="font-family: Montserrat, sans-serif;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LEAD CAPTURE FORM -->
  <section id="reserve" class="bg-white py-20">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-[#000094] font-semibold text-sm tracking-[4px] uppercase mb-2" style="font-family: Montserrat, sans-serif;">Ready to Ride?</p>
        <h2 class="text-4xl font-black text-gray-900" style="font-family: Montserrat, sans-serif;">Reserve Your Cart</h2>
        <p class="text-gray-500 mt-3" style="font-family: Montserrat, sans-serif;">Fill out the form and we'll be in touch within a few hours.</p>
      </div>

      <form id="reserveForm" class="bg-[#f5f7fa] rounded-3xl p-8 space-y-5 shadow-sm">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" style="font-family: Montserrat, sans-serif;">First Name</label>
            <input name="firstName" type="text" required placeholder="Rob"
              class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#000094]"
              style="font-family: Montserrat, sans-serif;" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" style="font-family: Montserrat, sans-serif;">Last Name</label>
            <input name="lastName" type="text" required placeholder="Hamilton"
              class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#000094]"
              style="font-family: Montserrat, sans-serif;" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" style="font-family: Montserrat, sans-serif;">Phone</label>
            <input name="phone" type="tel" required placeholder="(772) 262-8273"
              class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#000094]"
              style="font-family: Montserrat, sans-serif;" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" style="font-family: Montserrat, sans-serif;">Email</label>
            <input name="email" type="email" required placeholder="you@email.com"
              class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#000094]"
              style="font-family: Montserrat, sans-serif;" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" style="font-family: Montserrat, sans-serif;">Pickup Date</label>
            <input name="pickupDate" type="date" required
              class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#000094]"
              style="font-family: Montserrat, sans-serif;" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1" style="font-family: Montserrat, sans-serif;">Return Date</label>
            <input name="returnDate" type="date" required
              class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#000094]"
              style="font-family: Montserrat, sans-serif;" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1" style="font-family: Montserrat, sans-serif;">Number of Carts</label>
          <select name="numCarts" required
            class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#000094]"
            style="font-family: Montserrat, sans-serif;">
            <option value="">Select...</option>
            <option value="1">1 cart</option>
            <option value="2">2 carts</option>
            <option value="3">3 carts</option>
            <option value="4+">4+ carts</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1" style="font-family: Montserrat, sans-serif;">Message (optional)</label>
          <textarea name="message" rows="3" placeholder="Any questions or preferences?"
            class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#000094] resize-none"
            style="font-family: Montserrat, sans-serif;"></textarea>
        </div>

        <div id="formSuccess" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl px-4 py-3 text-sm" style="font-family: Montserrat, sans-serif;">
          ✅ Request received! We'll be in touch within a few hours.
        </div>
        <div id="formError" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl px-4 py-3 text-sm" style="font-family: Montserrat, sans-serif;">
          Something went wrong. Please call us directly at (772) 262-8273.
        </div>

        <button type="submit" id="submitBtn"
          class="w-full bg-[#000094] text-white font-bold text-lg py-4 rounded-full hover:bg-blue-900 transition-all shadow-md hover:shadow-lg disabled:opacity-60"
          style="font-family: Montserrat, sans-serif;">
          Send My Request
        </button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-white py-10">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <div class="font-black text-xl mb-1" style="font-family: Montserrat, sans-serif;">
            <span class="text-[#ffca1c]">Cool</span> Carts Rental
          </div>
          <p class="text-gray-400 text-sm" style="font-family: Montserrat, sans-serif;">Wildwood, FL &nbsp;|&nbsp; (772) 262-8273</p>
        </div>
        <div class="flex items-center gap-2 text-gray-500 text-sm" style="font-family: Montserrat, sans-serif;">
          <span>A sister company of</span>
          <a href="https://atomiccoolkartz.com" target="_blank" rel="noopener noreferrer" class="text-[#ffca1c] hover:text-yellow-300 font-semibold transition-colors">
            Atomic Cool Kartz
          </a>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-6 pt-6 text-center text-gray-600 text-xs" style="font-family: Montserrat, sans-serif;">
        &copy; {new Date().getFullYear()} Cool Carts Rental. All rights reserved.
      </div>
    </div>
  </footer>

</Layout>

<script>
  const form = document.getElementById('reserveForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  const success = document.getElementById('formSuccess')!;
  const error = document.getElementById('formError')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';
    success.classList.add('hidden');
    error.classList.add('hidden');

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('https://n8n.berrybloom.agency/webhook/cool-carts-rental-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        success.classList.remove('hidden');
        form.reset();
      } else {
        error.classList.remove('hidden');
      }
    } catch {
      error.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send My Request';
    }
  });
</script>
